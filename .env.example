# Sathya Nishta Environment Variables

# ──────────────────────────────────────────────────────────────
# Application (REQUIRED)
# ──────────────────────────────────────────────────────────────
APP_ENV=development  # development | production
LOG_LEVEL=DEBUG      # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change_this_to_a_secure_random_string_in_production

# ──────────────────────────────────────────────────────────────
# Neo4j Graph Database (REQUIRED)
# ──────────────────────────────────────────────────────────────
# For Cloud AuraDB (Recommended):
# NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-password

# For Local Docker (Alternative):
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# ──────────────────────────────────────────────────────────────
# Supabase / PostgreSQL (REQUIRED)
# ──────────────────────────────────────────────────────────────
# Connection string for SQLModel/Alembic
# Format: postgresql://user:password@host:port/database
# For Cloud Supabase:
# DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
# For Local Docker:
# DATABASE_URL=postgresql://postgres:password@postgres:5432/sathyanishta

# ──────────────────────────────────────────────────────────────
# AI Gateway (Portkey / Gemini) - OPTIONAL for Infra Setup
# ──────────────────────────────────────────────────────────────
# PORTKEY_API_KEY=your_portkey_api_key
# GEMINI_API_KEY=your_gemini_api_key

# ──────────────────────────────────────────────────────────────
# Traefik (Optional)
# ──────────────────────────────────────────────────────────────
# TRAEFIK_DASHBOARD_AUTH=user:hash  # For securing dashboard in prod
