# Sathya Nishta Environment Variables
# Sprint 1 — safe defaults for containerized testing (mock data, no real API keys needed)

# ──────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG

# ──────────────────────────────────────────────────────────────
# Neo4j Graph Database (dummy — no Neo4j container in Sprint 1)
# ──────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# ──────────────────────────────────────────────────────────────
# Supabase / PostgreSQL
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.mlcduxuznzihrtcuhmpv:SathyaNishta@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# The 'Anon' key (Public, obeys RLS)
SUPABASE_KEY=dummy-key
# The JWT Secret (Found in 'JWT Settings')
SUPABASE_JWT_SECRET=dummy-secret
# The 'Service Role' key (Secret, bypasses RLS - required for setup scripts)
SUPABASE_SERVICE_KEY=dummy-service-key

# ──────────────────────────────────────────────────────────────
# AI Gateway (all LLM calls route through Portkey)
# ──────────────────────────────────────────────────────────────
PORTKEY_API_KEY=dummy-portkey-key
# Config ID created in Portkey UI (controls model, routing, fallbacks)
PORTKEY_CONFIG_ID=
