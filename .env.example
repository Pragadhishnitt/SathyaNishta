# Sathya Nishta Environment Variables

# ──────────────────────────────────────────────────────────────
# Portkey (Cloud — REQUIRED)
# ──────────────────────────────────────────────────────────────
PORTKEY_API_KEY=your_portkey_api_key
PORTKEY_CONFIG=your_portkey_config_id

# ──────────────────────────────────────────────────────────────
# Gemini API (REQUIRED)
# ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# ──────────────────────────────────────────────────────────────
# Supabase (Cloud Only)
# ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ──────────────────────────────────────────────────────────────
# Neo4j (Cloud AuraDB or Local)
# ──────────────────────────────────────────────────────────────
# For local Neo4j (Docker service):
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=local_neo4j_password

# For cloud AuraDB:
# NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_neo4j_password

# ──────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────
APP_ENV=development  # development | production
LOG_LEVEL=DEBUG      # DEBUG | INFO | WARNING | ERROR

# ──────────────────────────────────────────────────────────────
# Production HTTPS (Let's Encrypt)
# ──────────────────────────────────────────────────────────────
# ACME_EMAIL=your-email@example.com
