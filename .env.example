# Sathya Nishta Environment Variables
# Sprint 1 — safe defaults for containerized testing (mock data, no real API keys needed)

# ──────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG
SECRET_KEY=dev-secret-key-not-for-production

# ──────────────────────────────────────────────────────────────
# Neo4j Graph Database (dummy — no Neo4j container in Sprint 1)
# ──────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# ──────────────────────────────────────────────────────────────
# Supabase / PostgreSQL (dummy — agents return stubs in Sprint 1)
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/sathyanishta
SUPABASE_URL=http://localhost:8000
SUPABASE_KEY=dummy-key
SUPABASE_SERVICE_KEY=dummy-service-key
SUPABASE_SECRET=dummy-secret

# ──────────────────────────────────────────────────────────────
# AI Gateway (dummy — agents return stubs in Sprint 1)
# ──────────────────────────────────────────────────────────────
PORTKEY_API_KEY=dummy-portkey-key
GEMINI_API_KEY=dummy-gemini-key
